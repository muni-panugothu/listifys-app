# Monorepo: EAS uploads from git root — ignore native/build artifacts under app/
app/android
app/ios
app/node_modules
app/.expo
app/.expo-export-test

# Gradle / CMake caches (often locked on Windows during local builds)
**/.gradle
**/.cxx
**/android/build
**/android/app/build

# Server is not part of the mobile build
server/node_modules

# Env and secrets
**/.env
**/.env.*

# Source control
.git
