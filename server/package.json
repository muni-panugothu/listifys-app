{
  "name": "auth-backend",
  "version": "1.0.0",
  "description": "Basic authentication backend",
  "main": "server.js",
  "scripts": {
    "start": "node --max-old-space-size=1024 cluster.js",
    "start:single": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --verbose --forceExit --detectOpenHandles",
    "test:coverage": "jest --verbose --forceExit --detectOpenHandles --coverage --coverageReporters=text --coverageReporters=lcov --coverageReporters=json-summary",
    "test:login": "jest tests/auth.login.test.js --verbose",
    "test:tokens": "jest tests/auth.tokens.test.js --verbose",
    "test:middleware": "jest tests/auth.middleware.test.js --verbose",
    "test:checkauth": "jest tests/auth.checkAuth.test.js --verbose",
    "test:registration": "jest tests/auth.registration.test.js --verbose",
    "test:password": "jest tests/auth.password.test.js --verbose",
    "test:model": "jest tests/auth.userModel.test.js --verbose",
    "test:security": "jest tests/auth.security.test.js --verbose"
  },
  "dependencies": {
    "@aws-crypto/sha256-js": "^5.2.0",
    "@aws-sdk/client-cloudwatch": "^3.1029.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1001.0",
    "@aws-sdk/client-s3": "^3.993.0",
    "@aws-sdk/credential-provider-node": "^3.972.33",
    "@aws-sdk/s3-request-presigner": "^3.993.0",
    "@elastic/elasticsearch": "^9.3.4",
    "@google-cloud/vertexai": "^1.12.0",
    "@google-cloud/vision": "^5.3.6",
    "@smithy/signature-v4": "^5.3.14",
    "@socket.io/redis-adapter": "^8.3.0",
    "@upstash/redis": "^1.36.1",
    "amqplib": "^1.0.3",
    "argon2": "^0.44.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.2.1",
    "geoip-lite": "^1.4.10",
    "google-auth-library": "^10.5.0",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "joi": "^18.1.1",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.0.0",
    "mongoose": "^9.2.1",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.12",
    "redis": "^4.7.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "twilio": "^6.0.0",
    "ua-parser-js": "^2.0.9",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "winston-cloudwatch": "^6.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
