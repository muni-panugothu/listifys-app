# ═══════════════════════════════════════════════════════════════════
# Listify — Server Environment Variables
# Copy this file to .env and fill in real values.
# When using Docker, use the ROOT .env file instead (../  .env).
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000
CLIENT_URL=http://localhost:80

# ── MongoDB ───────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────
JWT_SECRET=your-general-jwt-secret-min-64-chars
JWT_ACCESS_SECRET=your-access-secret-min-64-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-64-chars
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# ── Upstash Redis ─────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── Elasticsearch / OpenSearch ────────────────────────────────────
# Option A: AWS OpenSearch with fine-grained access control (username/password)
# ELASTICSEARCH_URL=https://search-your-domain-id.ap-south-1.es.amazonaws.com
# ELASTIC_USERNAME=your-master-username
# ELASTIC_PASSWORD=your-master-password
# AWS_OPENSEARCH_REGION=ap-south-1
# AWS_OPENSEARCH_IAM_AUTH=false

# Option B: AWS OpenSearch with IAM Sig v4
# ELASTICSEARCH_URL=https://search-your-domain-id.ap-south-1.es.amazonaws.com
# AWS_OPENSEARCH_IAM_AUTH=true
# AWS_OPENSEARCH_REGION=ap-south-1

# Option C: Elastic Cloud API key
# ELASTICSEARCH_URL=https://your-deployment.es.cloud.es.io:9243
# ELASTICSEARCH_API_KEY=your-base64-api-key

# Local Docker Elasticsearch fallback (if using bundled elasticsearch service)
# ELASTICSEARCH_URL=http://elasticsearch:9200
# ELASTIC_USERNAME=elastic
# ELASTIC_PASSWORD=your-strong-elastic-password

# ── AWS S3 ────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=your-secret
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=listify-uploads
AWS_S3_BUCKET_URL=https://listify-uploads.s3.us-east-1.amazonaws.com
# Optional: CloudFront distribution URL for CDN
# AWS_CLOUDFRONT_URL=https://d1234567.cloudfront.net

# ── Email (Gmail SMTP) ───────────────────────────────────────────
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
# EMAIL_FROM="Listify" <your-email@gmail.com>

# ── Google OAuth ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com

# ── Twilio (Phone OTP) ───────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Fallback if not using Messaging Service:
# TWILIO_PHONE_NUMBER=+1234567890

# ── Chat Encryption (AES-256-GCM) ────────────────────────────────
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: Do NOT lose this key — all stored messages become unreadable without it!
CHAT_ENCRYPTION_KEY=your-64-char-hex-key-here

# ── Admin Seed ────────────────────────────────────────────────────
# Optional fallback shared password (used only when a per-admin password is omitted)
ADMIN_SEED_PASSWORD=OptionalSharedPassword
# Update passwords for existing users matched by email during seeding
ADMIN_SEED_UPDATE_EXISTING_PASSWORDS=true
# Admin accounts (Name:email:password, comma-separated)
ADMIN_SEED_ACCOUNTS=Admin User:admin@example.com:ChangeMe@2026,Another Admin:admin2@example.com:ChangeMe@2026

# ── AWS CloudWatch Logging ────────────────────────────────────────
# Uses the same AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / AWS_REGION above.
# IAM user must have these permissions for CloudWatch Logs:
#   logs:CreateLogGroup, logs:CreateLogStream, logs:PutLogEvents,
#   logs:PutRetentionPolicy, logs:DescribeLogStreams
#
# Optional overrides (defaults shown):
# SERVICE_NAME=listify-api
# LOG_ENV=production                     # auto-detected from NODE_ENV
# LOG_RETENTION_DAYS=90                  # CloudWatch retention in days
# INSTANCE_ID=hostname-pid               # auto-detected; override for ECS/Fargate



# rabbitMQ
RABBITMQ_URL=amqps://user:password@your-rabbitmq-host.example.com/vhost