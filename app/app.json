{
  "expo": {
    "name": "Listifys",
    "slug": "Listify-App",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/splashscreenImg/logo.png",
    "scheme": "listifyapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Listify uses your location to show nearby listings and distances.",
        "NSMicrophoneUsageDescription": "Listify needs microphone access for voice search.",
        "NSSpeechRecognitionUsageDescription": "Listify uses speech recognition to search for listings by voice."
      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/splashscreenImg/logo.png",
        "backgroundImage": "./assets/splashscreenImg/logo.png",
        "monochromeImage": "./assets/splashscreenImg/logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.listifys.app",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/splashscreenImg/splashImg.png"
    },
    "plugins": [
      "./plugins/with-notifee-maven.js",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splashscreenImg/splashImg.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-audio",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Listify needs microphone access for voice search.",
          "speechRecognitionPermission": "Listify uses speech recognition to search for listings by voice."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      "@react-native-google-signin/google-signin",
      "expo-asset",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Listify uses your location to show nearby listings and distances."
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "92877557-302a-4609-ba74-54ffe704a8a2"
      }
    },
    "owner": "eagleiitech"
  }
}
