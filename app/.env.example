# ── Listify mobile app environment ───────────────────────────────────────────
# Copy to .env and set values for your environment.

# Backend API (required for production builds)
# Local dev on a physical device: leave empty — app auto-uses Expo Metro's LAN IP (:5000).
# If auto-detection fails, set your PC's IPv4 on the same Wi‑Fi as the phone.
# Example: http://192.168.1.100:5000
EXPO_PUBLIC_API_BASE_URL=

# Google OAuth (optional — app fetches from GET /api/auth/google/client-ids if omitted)
# Use the **Web** OAuth client ID from Google Cloud Console (required for Android idToken).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
