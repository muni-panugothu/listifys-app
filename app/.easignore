# Ignore local dependency installs
node_modules

# Ignore Expo and build artifacts
.expo
.expo-export-test

# Ignore IDE/editor files
.vscode
.idea

# Let EAS run a fresh expo prebuild — do not upload local native folders
android
android/**
ios
ios/**

# Gradle / native caches (locked on Windows if a local build is running)
**/.gradle
**/.gradle/**
**/.cxx

# Ignore temporary and log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.DS_Store
yarn.lock
pnpm-lock.yaml

# Ignore environment files
.env
.env.*

# Ignore local bundles/build outputs
*.keystore
*.jks
*.map

# Ignore any generated output not needed for EAS Build
**/dist
**/build
**/.next

# Ignore source control metadata
.git
