# Ignore local dependency installs
node_modules

# Ignore Expo and build artifacts
.expo
.expo-export-test

# Ignore IDE/editor files
.vscode
.idea

# Ignore Android build outputs and caches
android/.gradle
android/app/build
android/build
android/gradle
android/gradle-wrapper.jar

# Ignore temporary and log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.DS_Store
package-lock.json
yarn.lock
pnpm-lock.yaml

# Ignore environment files
.env
.env.*

# Ignore local bundles/build outputs
*.keystore
*.jks
*.map

# Ignore any generated output not needed for EAS Build
**/dist
**/build
**/.next

# Ignore source control metadata
.git
