# Backend API base URL
# In local dev on a phone, leave this empty — the app uses the same LAN IP as Expo Metro.
# Set only for production builds or when Metro host detection is unavailable.
#EXPO_PUBLIC_API_BASE_URL=http://10.22.25.71:5000
EXPO_PUBLIC_API_BASE_URL=https://listifys-app.onrender.com
#EXPO_PUBLIC_API_BASE_URL=http://10.22.67.95:5000
#EXPO_PUBLIC_API_BASE_URL=http://192.168.0.101:5000
#EXPO_PUBLIC_API_BASE_URL=http://192.168.1.9:5000

EXPO_PUBLIC_API_BASE_URL=https://listifys-app.onrender.com

# Google Maps Static API key
# Get one at: https://console.cloud.google.com/apis/credentials
# Enable "Maps Static API" in your Google Cloud project
# Free: $200/month credit (~28,500 static map loads/month)
EXPO_PUBLIC_GOOGLE_MAPS_KEY=AIzaSyDE0mXggZkkQxJKiogRvdT73J5yOqj6dVI

# Google OAuth (Web client ID used by native Google Sign-In for idToken)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=582870381419-ks689jiqpd5kuvurcbpc50bps6nlvbnk.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=335766515911-59brg6j33qda5bg3lbbabj08oqshnq3a.apps.googleusercontent.com
